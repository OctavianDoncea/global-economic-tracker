# Warehouse Configuration
# Options: "duckdb" (local, zero setup) or "bigquery" (requires GCP account)
WAREHOUSE=duckdb

# DuckDB settings (only needed if WAREHOUSE=duckdb)
DUCKDB_PATH=data/warehouse.duckdb

# BigQuery settings (only needed if WAREHOUSE=bigquery)
# GCP_PROJECT_ID=your-gcp-project-id
# BQ_DATASET=raw
# BQ_LOCATION=US
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json

# API Keys
# FRED API key (required for FRED source)
# Get yours free at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here